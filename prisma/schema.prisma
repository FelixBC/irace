generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled (Neon / Vercel serverless); migrations use direct connection below
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  emailVerified  DateTime?
  image          String?
  stravaId       String?         @unique
  stravaTokens   Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  activities     Activity[]
  challenges     Challenge[]     @relation("ChallengeCreator")
  participations Participation[]
  sessions       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Challenge {
  id              String          @id @default(cuid())
  name            String
  description     String?
  sports          Sport[]
  challengeType   ChallengeType   @default(DISTANCE)
  goal            Float
  goalUnit        String
  duration        String
  startDate       DateTime
  endDate         DateTime
  isPublic        Boolean         @default(true)
  inviteCode      String          @unique
  maxParticipants Int             @default(10)
  status          ChallengeStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  creatorId       String
  sportGoals      Json?
  /// Creator acknowledged that invitees will see peer progress in this challenge (community app model).
  creatorParticipantSharingAckAt DateTime?
  activities      Activity[]
  creator         User            @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants    Participation[]

  @@index([creatorId])
  @@index([startDate, endDate])
  @@index([inviteCode])
  @@index([status])
  @@index([isPublic])
}

model Participation {
  id               String              @id @default(cuid())
  userId           String
  challengeId      String
  avatarId         String?
  joinedAt         DateTime            @default(now())
  status           ParticipationStatus @default(ACTIVE)
  progress         Json?
  lastActivityDate DateTime?
  currentDistance  Float               @default(0)
  lastActivityAt   DateTime?
  /// When set, this user agreed that aggregated challenge stats may be shown to other participants in this challenge (Strava API / community-challenge model).
  challengeDataConsentAt      DateTime?
  challengeDataConsentVersion String              @default("1")
  challenge        Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@index([status])
  @@index([avatarId])
}

model Activity {
  id               String     @id @default(cuid())
  stravaActivityId String     @unique
  userId           String
  challengeId      String?
  sport            Sport
  distance         Float
  duration         Int
  date             DateTime
  synced           Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  challenge        Challenge? @relation(fields: [challengeId], references: [id])
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([challengeId])
  @@index([sport])
  @@index([date])
  @@index([stravaActivityId])
}

model Avatar {
  id          String   @id @default(cuid())
  name        String
  description String?
  sport       Sport
  imageUrl    String
  isPremium   Boolean  @default(false)
  price       Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sport])
  @@index([isPremium])
  @@index([isActive])
}

enum Sport {
  RUNNING
  CYCLING
  SWIMMING
  WALKING
  HIKING
  YOGA
  WEIGHT_TRAINING
}

enum ChallengeType {
  DISTANCE
  TIME
  FREQUENCY
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  DRAFT
}

enum ParticipationStatus {
  ACTIVE
  COMPLETED
  DROPPED
  INVITED
}
